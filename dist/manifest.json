{
  "manifest_version": 3,
  "name": "TabNest",
  "version": "1.0.0",
  "description": "TabNest automatically organizes tabs into smart groups and manages them through a 4-stage lifecycle to save RAM and reduce clutter.",
  "permissions": [
    "tabs",
    "storage",
    "alarms",
    "sidePanel",
    "webNavigation",
    "activeTab"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "sidebar/sidebar.html"
  },
  "action": {
    "default_title": "Open TabNest Sidebar",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/form-detector.js"],
      "run_at": "document_idle",
      "all_frames": false
    },
    {
      "matches": ["<all_urls>"],
      "js": ["content/history-capture.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  },
  "minimum_chrome_version": "114",
  "commands": {
    "toggle-sidebar": {
      "suggested_key": { "default": "Ctrl+Shift+T" },
      "description": "Toggle the TabNest sidebar"
    },
    "save-close-current": {
      "suggested_key": { "default": "Ctrl+Shift+S" },
      "description": "Save and close the current tab"
    },
    "restore-last": {
      "suggested_key": { "default": "Ctrl+Shift+R" },
      "description": "Restore the most recently saved tab"
    },
    "search-tabs": {
      "suggested_key": { "default": "Ctrl+Shift+F" },
      "description": "Focus the sidebar search input"
    },
    "next-group": {
      "description": "Move focus to the next tab group"
    },
    "prev-group": {
      "description": "Move focus to the previous tab group"
    },
    "save-close-all": {
      "description": "Save and close all inactive tabs"
    },
    "discard-current": {
      "description": "Discard the current tab"
    }
  }
}
