{
  "manifest_version": 2,
  "name": "TabNest",
  "version": "0.1.0",
  "description": "Automatic tab lifecycle management with smart grouping — Active, Discard, Save & Close, Archive.",
  "permissions": [
    "tabs",
    "storage",
    "alarms",
    "webNavigation",
    "activeTab",
    "<all_urls>"
  ],
  "background": {
    "scripts": ["background-firefox.js"],
    "persistent": true
  },
  "sidebar_action": {
    "default_title": "TabNest",
    "default_panel": "sidebar/sidebar.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "browser_action": {
    "default_title": "Open TabNest Sidebar",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/form-detector.js"],
      "run_at": "document_idle",
      "all_frames": false
    },
    {
      "matches": ["<all_urls>"],
      "js": ["content/history-capture.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "content_security_policy": "script-src 'self'; object-src 'self'",
  "browser_specific_settings": {
    "gecko": {
      "id": "tabnest@extension",
      "strict_min_version": "109.0"
    }
  }
}
