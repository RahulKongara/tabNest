{
  "manifest_version": 2,
  "name": "TabNest",
  "version": "0.1.0",
  "description": "Automatic tab lifecycle management with smart grouping — Active, Discard, Save & Close, Archive.",
  "permissions": [
    "tabs",
    "storage",
    "alarms",
    "webNavigation",
    "activeTab",
    "<all_urls>"
  ],
  "background": {
    "scripts": [
      "core/browser-adapter.js",
      "core/constants.js",
      "core/lifecycle-manager.js",
      "core/grouping-engine.js",
      "core/storage-manager.js",
      "core/url-analyzer.js",
      "core/restore-manager.js",
      "sidebar/message-protocol.js",
      "background-firefox.js"
    ],
    "persistent": true
  },
  "sidebar_action": {
    "default_title": "TabNest",
    "default_panel": "sidebar/sidebar.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "browser_action": {
    "default_title": "Open TabNest Sidebar",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/form-detector.js"],
      "run_at": "document_idle",
      "all_frames": false
    },
    {
      "matches": ["<all_urls>"],
      "js": ["content/history-capture.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "commands": {
    "toggle-sidebar": {
      "suggested_key": { "default": "Ctrl+Shift+T" },
      "description": "Toggle the TabNest sidebar"
    },
    "save-close-current": {
      "suggested_key": { "default": "Ctrl+Shift+S" },
      "description": "Save and close the current tab"
    },
    "restore-last": {
      "suggested_key": { "default": "Ctrl+Shift+R" },
      "description": "Restore the most recently saved tab"
    },
    "next-group": {
      "suggested_key": { "default": "Ctrl+Shift+]" },
      "description": "Move focus to the next tab group"
    },
    "prev-group": {
      "suggested_key": { "default": "Ctrl+Shift+[" },
      "description": "Move focus to the previous tab group"
    },
    "save-close-all": {
      "suggested_key": { "default": "Ctrl+Shift+X" },
      "description": "Save and close all inactive tabs"
    },
    "search-tabs": {
      "suggested_key": { "default": "Ctrl+Shift+F" },
      "description": "Focus the sidebar search input"
    },
    "discard-current": {
      "suggested_key": { "default": "Ctrl+Shift+D" },
      "description": "Discard the current tab"
    }
  },
  "content_security_policy": "script-src 'self'; object-src 'self'",
  "browser_specific_settings": {
    "gecko": {
      "id": "tabnest@extension",
      "strict_min_version": "109.0"
    }
  }
}
